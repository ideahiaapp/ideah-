# ============================================
# @ideah/web — Environment Variables
# Copy to .env.local (dev) and set the same vars on Vercel (Production).
# DO NOT commit real values.
# ============================================

# --------------------------------------------
# Public — exposed to the browser (NEXT_PUBLIC_ prefix is REQUIRED)
# Inlined at build time. Missing these breaks the app at runtime.
# --------------------------------------------

# Supabase project URL — Dashboard > Settings > API > Project URL
# e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL of the apps/api backend (optional — defaults to http://localhost:3001)
NEXT_PUBLIC_API_URL=

# --------------------------------------------
# Server-only — secrets. NEVER prefix these with NEXT_PUBLIC_
# (that would leak them into the client bundle).
# On a Turborepo monorepo, also declare new vars in turbo.json > tasks.build.env.
# --------------------------------------------

# Supabase service role key (admin, bypasses RLS) — Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key (supervision chat, reports) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voyage AI key (RAG embeddings) — https://dashboard.voyageai.com/
VOYAGE_API_KEY=

# Resend key (anamnese e-mails) — https://resend.com/api-keys
RESEND_API_KEY=
