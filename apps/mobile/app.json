{
  "expo": {
    "name": "Paideia",
    "slug": "paideia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/paideia-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ideah-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#924B92"
    },
    "scheme": "paideia",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.com.paideia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/paideia-adaptive-icon.png",
        "backgroundColor": "#c2542f"
      },
      "package": "br.com.paideia.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
  }
}
